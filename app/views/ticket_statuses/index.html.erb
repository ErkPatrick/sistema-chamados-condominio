<% content_for(:title, "Status de Chamados") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Status de Chamados</h1>
  <%= link_to "Novo Status", new_ticket_status_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
</div>

<div class="bg-white rounded-lg shadow p-4 mb-4">
  <%= form_with url: ticket_statuses_path, method: :get, class: "flex gap-3 items-end" do |f| %>
    <div class="flex-1">
      <%= f.label :name, "Nome", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, value: params[:name], placeholder: "Buscar por nome...",
          class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    <%= f.submit "Filtrar", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700 cursor-pointer" %>
    <% if params[:name].present? %>
      <%= link_to "Limpar", ticket_statuses_path, class: "bg-gray-200 text-gray-700 px-4 py-2 rounded text-sm hover:bg-gray-300" %>
    <% end %>
  <% end %>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50">
      <tr class="text-left text-gray-500">
        <th class="px-4 py-3">Nome</th>
        <th class="px-4 py-3">Padrão</th>
        <th class="px-4 py-3">Final</th>
        <th class="px-4 py-3">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% if @ticket_statuses.any? %>
        <% @ticket_statuses.each do |status| %>
          <tr class="border-t hover:bg-gray-50">
            <td class="px-4 py-3 font-medium"><%= status.name %></td>
            <td class="px-4 py-3">
              <% if status.is_default? %>
                <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">Padrão</span>
              <% else %>
                <span class="text-gray-400">—</span>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <% if status.is_final? %>
                <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">Final</span>
              <% else %>
                <span class="text-gray-400">—</span>
              <% end %>
            </td>
            <td class="px-4 py-3 flex gap-2">
              <%= link_to "Editar", edit_ticket_status_path(status), class: "text-white font-semibold bg-yellow-500 hover:bg-yellow-600 px-3 py-1 rounded" %>
              <%= button_to "Remover", ticket_status_path(status), method: :delete,
                  form: { data: { turbo_confirm: "Tem certeza?" } },
                  class: "text-white font-semibold bg-red-600 hover:bg-red-700 px-3 py-1 rounded" %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr><td colspan="4" class="px-4 py-6 text-center text-gray-400">Nenhum status encontrado.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>