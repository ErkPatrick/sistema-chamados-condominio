<% content_for(:title, "Editar Status") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Editar Status</h1>
  <%= link_to "Voltar", ticket_statuses_path, class: "bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300" %>
</div>

<div class="bg-white rounded-lg shadow p-6">
  <%= form_with model: @ticket_status, class: "space-y-4" do |f| %>
    <% if @ticket_status.errors.any? %>
      <div class="bg-red-100 text-red-800 px-4 py-3 rounded">
        <p class="font-semibold mb-1"><%= pluralize(@ticket_status.errors.count, "erro") %> encontrado(s):</p>
        <ul class="list-disc list-inside text-sm">
          <% @ticket_status.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Nome", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="flex gap-6">
      <div class="flex items-center gap-2">
        <%= f.check_box :is_default, class: "w-4 h-4 text-blue-600" %>
        <%= f.label :is_default, "Status Padrão", class: "text-sm text-gray-700" %>
      </div>
      <div class="flex items-center gap-2">
        <%= f.check_box :is_final, class: "w-4 h-4 text-blue-600" %>
        <%= f.label :is_final, "Status Final", class: "text-sm text-gray-700" %>
      </div>
    </div>

    <div class="bg-yellow-50 border border-yellow-200 rounded p-3 text-sm text-yellow-800">
        OBS: Apenas um status pode ser padrão e apenas um pode ser final no sistema.
    </div>

    <div class="flex gap-2 pt-2">
      <%= f.submit "Salvar Alterações", class: "bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "Cancelar", ticket_statuses_path, class: "bg-gray-200 text-gray-700 px-6 py-2 rounded hover:bg-gray-300" %>
    </div>
  <% end %>
</div>