<% content_for(:title, "Dashboard") %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Dashboard</h1>
  <p class="text-gray-500">Bem-vindo, <%= current_user.name %>!</p>
</div>

<% if current_user.admin?  || current_user.collaborator? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-sm text-gray-500">Total de Chamados</p>
      <p class="text-3xl font-bold text-gray-800"><%= @total_tickets %></p>
    </div>
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-sm text-gray-500">Chamados Abertos</p>
      <p class="text-3xl font-bold text-yellow-500"><%= @open_tickets %></p>
    </div>
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-sm text-gray-500">Chamados Concluídos</p>
      <p class="text-3xl font-bold text-green-500"><%= @closed_tickets %></p>
    </div>
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-sm text-gray-500">Total de Blocos</p>
      <p class="text-3xl font-bold text-blue-500"><%= @total_blocks %></p>
    </div>
  </div>

<% elsif current_user.resident? %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-sm text-gray-500">Meus Chamados Abertos</p>
      <p class="text-3xl font-bold text-yellow-500"><%= @open_tickets %></p>
    </div>
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-sm text-gray-500">Meus Chamados Concluídos</p>
      <p class="text-3xl font-bold text-green-500"><%= @closed_tickets %></p>
    </div>
  </div>
<% end %>

<div class="bg-white rounded-lg shadow p-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-gray-800">Chamados Recentes</h2>
    <%= link_to "Ver todos", tickets_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
  </div>
  <% if @recent_tickets.any? %>
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-gray-500 border-b">
          <th class="pb-2">ID</th>
          <th class="pb-2">Unidade</th>
          <th class="pb-2">Tipo</th>
          <th class="pb-2">Status</th>
          <th class="pb-2">Aberto em</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_tickets.each do |ticket| %>
          <tr class="border-b hover:bg-gray-50">
            <td class="py-2">#<%= ticket.id %></td>
            <td class="py-2"><%= ticket.unit.identifier %></td>
            <td class="py-2"><%= ticket.ticket_type.title %></td>
            <td class="py-2"><%= ticket.ticket_status.name %></td>
            <td class="py-2"><%= ticket.opened_at.strftime("%d/%m/%Y") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-gray-400 text-sm">Nenhum chamado encontrado.</p>
  <% end %>
</div>