<% content_for(:title, "Login") %>

<div class="min-h-screen flex items-center justify-center">
  <div class="bg-white rounded-lg shadow p-8 w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-blue-600">Condomínio</h1>
      <p class="text-gray-500 mt-2">Sistema de Gerenciamento de Chamados</p>
    </div>

    <%= form_with model: resource, as: resource_name, url: session_path(resource_name), class: "space-y-4" do |f| %>
      <% if flash[:alert] %>
        <div class="bg-red-100 text-red-800 px-4 py-3 rounded text-sm">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <div>
        <%= f.label :email, "E-mail", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div>
        <%= f.label :password, "Senha", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "w-4 h-4 text-blue-600" %>
          <%= f.label :remember_me, "Lembrar de mim", class: "text-sm text-gray-600" %>
        </div>
        <%= link_to "Esqueceu sua senha?", new_password_path(resource_name), class: "text-sm text-blue-600 hover:underline" %>
      </div>

      <%= f.submit "Entrar", class: "w-full bg-blue-600 text-white py-2 rounded hover:bg-blue-700 cursor-pointer font-medium" %>
    <% end %>
  </div>
</div>