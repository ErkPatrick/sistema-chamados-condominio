<% content_for(:title, "Editar Tipo de Chamado") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Editar Tipo de Chamado</h1>
  <%= link_to "Voltar", ticket_types_path, class: "bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300" %>
</div>

<div class="bg-white rounded-lg shadow p-6">
  <%= form_with model: @ticket_type, class: "space-y-4" do |f| %>
    <% if @ticket_type.errors.any? %>
      <div class="bg-red-100 text-red-800 px-4 py-3 rounded">
        <p class="font-semibold mb-1"><%= pluralize(@ticket_type.errors.count, "erro") %> encontrado(s):</p>
        <ul class="list-disc list-inside text-sm">
          <% @ticket_type.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :title, "Título", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :title, class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :sla_hours, "SLA (em horas)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :sla_hours, min: 1, class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      <p class="text-xs text-gray-400 mt-1">Prazo máximo de resolução em horas. Ex: 24 = 1 dia</p>
    </div>

    <div class="flex gap-2 pt-2">
      <%= f.submit "Salvar Alterações", class: "bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "Cancelar", ticket_types_path, class: "bg-gray-200 text-gray-700 px-6 py-2 rounded hover:bg-gray-300" %>
    </div>
  <% end %>
</div>