<% content_for(:title, "Tipos de Chamado") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Tipos de Chamado</h1>
  <%= link_to "Novo Tipo", new_ticket_type_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
</div>

<div class="bg-white rounded-lg shadow p-4 mb-4">
  <%= form_with url: ticket_types_path, method: :get, class: "flex gap-3 items-end" do |f| %>
    <div class="flex-1">
      <%= f.label :title, "Título", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :title, value: params[:title], placeholder: "Buscar por título...",
          class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    <%= f.submit "Filtrar", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700 cursor-pointer" %>
    <% if params[:title].present? %>
      <%= link_to "Limpar", ticket_types_path, class: "bg-gray-200 text-gray-700 px-4 py-2 rounded text-sm hover:bg-gray-300" %>
    <% end %>
  <% end %>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50">
      <tr class="text-left text-gray-500">
        <th class="px-4 py-3">Título</th>
        <th class="px-4 py-3">SLA (horas)</th>
        <th class="px-4 py-3">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% if @ticket_types.any? %>
        <% @ticket_types.each do |ticket_type| %>
          <tr class="border-t hover:bg-gray-50">
            <td class="px-4 py-3 font-medium"><%= ticket_type.title %></td>
            <td class="px-4 py-3"><%= ticket_type.sla_hours %>h</td>
            <td class="px-4 py-3 flex gap-2">
              <%= link_to "Editar", edit_ticket_type_path(ticket_type), class: "text-white font-semibold bg-yellow-500 px-2 py-1 rounded cursor-pointer hover:bg-yellow-600" %>
              <%= button_to "Remover", ticket_type_path(ticket_type), method: :delete,
                  form: { data: { turbo_confirm: "Tem certeza?" } },
                  class: "text-white font-semibold bg-red-500 px-2 py-1 rounded cursor-pointer hover:bg-red-600" %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr><td colspan="3" class="px-4 py-6 text-center text-gray-400">Nenhum tipo encontrado.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>