<% content_for(:title, "Unidade #{@unit.identifier}") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Unidade <%= @unit.identifier %></h1>
  <%= link_to "Voltar", block_path(@unit.block), class: "bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300" %>
</div>

<div class="bg-white rounded-lg shadow p-6 mb-6">
  <h2 class="text-lg font-semibold text-gray-800 mb-4">Informações</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div>
      <p class="text-sm text-gray-500">Identificador</p>
      <p class="text-gray-800 font-medium"><%= @unit.identifier %></p>
    </div>
    <div>
      <p class="text-sm text-gray-500">Bloco</p>
      <p class="text-gray-800 font-medium"><%= @unit.block.identifier %></p>
    </div>
    <div>
      <p class="text-sm text-gray-500">Andar</p>
      <p class="text-gray-800 font-medium"><%= @unit.floor %></p>
    </div>
  </div>
</div>

<div class="bg-white rounded-lg shadow p-6 mb-6">
  <h2 class="text-lg font-semibold text-gray-800 mb-4">Moradores</h2>
  <% if @unit.users.any? %>
    <table class="w-full text-sm mb-4">
      <thead class="bg-gray-50">
        <tr class="text-left text-gray-500">
          <th class="px-4 py-3">Nome</th>
          <th class="px-4 py-3">E-mail</th>
          <th class="px-4 py-3">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% @unit.users.each do |user| %>
          <tr class="border-t hover:bg-gray-50">
            <td class="px-4 py-3"><%= user.name %></td>
            <td class="px-4 py-3"><%= user.email %></td>
            <td class="px-4 py-3">
              <%= button_to "Desvincular",
                  unit_unit_user_path(@unit, @unit.unit_users.find_by(user: user)),
                  method: :delete,
                  data: { turbo_confirm: "Tem certeza?" },
                  class: "text-red-500 text-sm hover:underline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-gray-400 text-sm mb-4">Nenhum morador vinculado.</p>
  <% end %>

  <% if current_user.admin? %>
    <div class="border-t border-gray-400 pt-4">
      <h3 class="text-md font-semibold text-gray-700 mb-3">Vincular Morador</h3>
      <%= form_with url: unit_unit_users_path(@unit), class: "flex gap-2" do |f| %>
        <%= f.select :user_id, User.resident.map { |u| [u.name, u.id] },
            { prompt: "Selecione um morador" },
            class: "border rounded px-3 py-2 text-sm flex-1" %>
        <%= f.submit "Vincular", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700" %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="bg-white rounded-lg shadow p-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-gray-800">Chamados</h2>
    <%= link_to "Ver todos", tickets_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
  </div>
  <% if @unit.tickets.any? %>
    <table class="w-full text-sm">
      <thead class="bg-gray-50">
        <tr class="text-left text-gray-500">
          <th class="px-4 py-3">ID</th>
          <th class="px-4 py-3">Tipo</th>
          <th class="px-4 py-3">Status</th>
          <th class="px-4 py-3">Aberto em</th>
          <th class="px-4 py-3">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% @unit.tickets.order(created_at: :desc).each do |ticket| %>
          <tr class="border-t hover:bg-gray-50">
            <td class="px-4 py-3">#<%= ticket.id %></td>
            <td class="px-4 py-3"><%= ticket.ticket_type.title %></td>
            <td class="px-4 py-3"><%= ticket.ticket_status.name %></td>
            <td class="px-4 py-3"><%= ticket.opened_at.strftime("%d/%m/%Y") %></td>
            <td class="px-4 py-3">
              <%= link_to "Ver", ticket_path(ticket), class: "text-blue-600 hover:underline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-gray-400 text-sm">Nenhum chamado encontrado.</p>
  <% end %>
</div>