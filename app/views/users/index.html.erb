<% content_for(:title, "Usuários") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Usuários</h1>
  <%= link_to "Novo Usuário", new_user_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50">
      <tr class="text-left text-gray-500">
        <th class="px-4 py-3">Nome</th>
        <th class="px-4 py-3">E-mail</th>
        <th class="px-4 py-3">Perfil</th>
        <th class="px-4 py-3">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr class="border-t hover:bg-gray-50">
          <td class="px-4 py-3"><%= user.name %></td>
          <td class="px-4 py-3"><%= user.email %></td>
          <td class="px-4 py-3">
            <% if user.admin? %>
              <span class="bg-purple-100 text-purple-800 text-xs px-2 py-1 rounded">Administrador</span>
            <% elsif user.collaborator? %>
              <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">Colaborador</span>
            <% elsif user.resident? %>
              <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">Morador</span>
            <% end %>
          </td>
          <td class="px-4 py-3 flex gap-2">
            <%= link_to "Ver", user_path(user), class: "text-white bg-blue-500 px-2 py-1 rounded cursor-pointer hover:bg-blue-600" %>
            <%= link_to "Editar", edit_user_path(user), class: "text-white bg-yellow-500 px-2 py-1 rounded cursor-pointer hover:bg-yellow-600" %>
            <%= button_to "Remover", user_path(user), method: :delete, data: { turbo_confirm: "Tem certeza?" }, class: "text-white bg-red-500 px-2 py-1 rounded cursor-pointer hover:bg-red-600" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>