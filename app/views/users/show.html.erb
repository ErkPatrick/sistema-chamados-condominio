<% content_for(:title, "Informações do Usuário") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800"><%= @user.name %></h1>
  <div class="flex gap-2">
    <%= link_to "Editar", edit_user_path(@user), class: "bg-yellow-500 text-white px-4 py-2 rounded hover:bg-yellow-600" %>
    <%= link_to "Voltar", users_path, class: "bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300" %>
  </div>
</div>

<div class="bg-white rounded-lg shadow p-6 mb-6">
  <h2 class="text-xl font-bold text-gray-800 mb-4">Informações</h2>
  <hr class="border-gray-300 mb-4">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <p class="text-sm text-gray-500">Nome</p>
      <p class="text-gray-800 font-medium"><%= @user.name %></p>
    </div>
    <div>
      <p class="text-sm text-gray-500">E-mail</p>
      <p class="text-gray-800 font-medium"><%= @user.email %></p>
    </div>
    <div>
      <p class="text-sm text-gray-500">Perfil</p>
      <% if @user.admin? %>
        <span class="bg-purple-100 text-purple-800 text-xs px-2 py-1 rounded">Administrador</span>
      <% elsif @user.collaborator? %>
        <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">Colaborador</span>
      <% elsif @user.resident? %>
        <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">Morador</span>
      <% end %>
    </div>
  </div>
</div>

<% if @user.resident? %>
  <div class="bg-white rounded-lg shadow p-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-4">Unidades Vinculadas</h2>
    <% if @user.units.any? %>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <% @user.units.each do |unit| %>
          <div class="border rounded-lg p-4 flex items-center justify-between">
            <span class="font-medium text-gray-800"><%= unit.identifier %></span>
            <%= link_to "Ver unidade", unit_path(unit), class: "text-blue-500 text-sm hover:underline" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-400 text-sm">Nenhuma unidade vinculada.</p>
      <p class="text-gray-400 text-sm mt-1">Para vincular, acesse a página da unidade desejada.</p>
    <% end %>
  </div>
<% end %>