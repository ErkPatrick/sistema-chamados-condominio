<% content_for(:title, "Editar Usuário") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Editar <span class="font-normal italic"><%= @user.name %></span></h1>
  <%= link_to "Voltar", users_path, class: "bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300" %>
</div>

<div class="bg-white rounded-lg shadow p-6">
  <%= form_with model: @user, class: "space-y-4" do |f| %>
    <% if @user.errors.any? %>
      <div class="bg-red-100 text-red-800 px-4 py-3 rounded">
        <p class="font-semibold mb-1"><%= pluralize(@user.errors.count, "erro") %> encontrado(s):</p>
        <ul class="list-disc list-inside text-sm">
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %> 
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Nome", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :email, "E-mail", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :password, "Senha", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password, class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      <p class="text-xs text-gray-400 mt-1">Deixe em branco para manter a senha atual.</p>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirmar Senha", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password_confirmation, class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :role, "Perfil", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :role, [["Administrador", "admin"], ["Colaborador", "collaborator"], ["Morador", "resident"]],
          { prompt: "Selecione um perfil" },
          class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="flex gap-2 pt-2">
      <%= f.submit "Salvar Alterações", class: "bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "Cancelar", users_path, class: "bg-gray-200 text-gray-700 px-6 py-2 rounded hover:bg-gray-300" %>
    </div>
  <% end %>
</div>