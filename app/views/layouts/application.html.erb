<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Sistema de Chamados" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>
  <body class="bg-gray-100 min-h-screen">

    <% if user_signed_in? %>
      <nav class="bg-white shadow mb-8">
        <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
          <span class="text-xl font-bold text-blue-600">Condomínio</span>
          <div class="flex items-center gap-6">
            <%= link_to "Dashboard", root_path, class: "text-gray-600 hover:text-blue-600" %>  
            <%= link_to "Chamados", tickets_path, class: "text-gray-600 hover:text-blue-600" %>
            <% if current_user.admin? %>
              <%= link_to "Blocos", blocks_path, class: "text-gray-600 hover:text-blue-600" %>
              <%= link_to "Usuários", users_path, class: "text-gray-600 hover:text-blue-600" %>
              <%= link_to "Tipos de Chamado", ticket_types_path, class: "text-gray-600 hover:text-blue-600" %>
              <%= link_to "Status", ticket_statuses_path, class: "text-gray-600 hover:text-blue-600" %>
            <% end %>
            <span class="text-gray-400">|</span>
            <span class="text-sm font-semibold text-black-500"><%= current_user.name %></span>
            <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "text-sm font-semibold text-red-500 hover:text-red-700 cursor-pointer" %>
          </div>
        </div>
      </nav>
    <% end %>

    <main class="max-w-7xl mx-auto px-4">
      <% if notice %>
        <div class="bg-green-100 text-green-800 px-4 py-3 rounded mb-4">
          <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div class="bg-red-100 text-red-800 px-4 py-3 rounded mb-4">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>

  </body>
</html>