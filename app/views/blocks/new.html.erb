<% content_for(:title, "Novo Bloco") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Novo Bloco</h1>
  <%= link_to "Voltar", blocks_path, class: "bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300" %>
</div>

<div class="bg-white rounded-lg shadow p-6">
  <%= form_with model: @block, class: "space-y-4" do |f| %>
    <% if @block.errors.any? %>
      <div class="bg-red-100 text-red-800 px-4 py-3 rounded">
        <p class="font-semibold mb-1"><%= pluralize(@block.errors.count, "erro") %> encontrado(s):</p>
        <ul class="list-disc list-inside text-sm">
          <% @block.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :identifier, "Identificador", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :identifier, placeholder: "Ex: A, B, C",
          class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :floors, "Quantidade de Andares", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :floors, min: 1,
          class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :units_per_floor, "Apartamentos por Andar", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :units_per_floor, min: 1,
          class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="bg-yellow-50 border border-yellow-200 rounded p-3 text-sm text-yellow-800">
      OBS: As unidades serão geradas automaticamente após a criação do bloco.
    </div>

    <div class="flex gap-2 pt-2">
      <%= f.submit "Criar Bloco", class: "bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "Cancelar", blocks_path, class: "bg-gray-200 text-gray-700 px-6 py-2 rounded hover:bg-gray-300" %>
    </div>
  <% end %>
</div>