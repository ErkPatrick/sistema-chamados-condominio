<% content_for(:title, "Chamado ##{@ticket.id}") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Chamado #<%= @ticket.id %></h1>
  <%= link_to "Voltar", tickets_path, class: "bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300" %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <div class="lg:col-span-2 space-y-6">

    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold text-gray-800 mb-4">Informações</h2>
      <hr class="border-gray-300 mb-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-gray-500">Unidade</p>
          <p class="text-gray-800 font-medium"><%= @ticket.unit.identifier %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Tipo</p>
          <p class="text-gray-800 font-medium"><%= @ticket.ticket_type.title %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Aberto por</p>
          <p class="text-gray-800 font-medium"><%= @ticket.user.name %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Aberto em</p>
          <p class="text-gray-800 font-medium"><%= @ticket.opened_at.strftime("%d/%m/%Y %H:%M") %></p>
        </div>
        <% if @ticket.closed_at %>
          <div>
            <p class="text-sm text-gray-500">Concluído em</p>
            <p class="text-gray-800 font-medium"><%= @ticket.closed_at.strftime("%d/%m/%Y %H:%M") %></p>
          </div>
        <% end %>
        <div>
          <p class="text-sm text-gray-500">SLA</p>
          <% sla_deadline = @ticket.opened_at + @ticket.ticket_type.sla_hours.hours %>
          <% if @ticket.ticket_status.is_final? %>
            <span class="text-green-600 font-medium">Concluído no prazo</span>
          <% elsif Time.current > sla_deadline %>
            <span class="text-red-600 font-medium">Atrasado</span>
          <% else %>
            <span class="text-gray-800 font-medium">Até <%= sla_deadline.strftime("%d/%m/%Y %H:%M") %></span>
          <% end %>
        </div>
      </div>

      <div class="mt-4">
        <p class="text-sm text-gray-500 mb-1">Descrição</p>
        <p class="text-gray-800 bg-gray-50 rounded p-3"><%= @ticket.description %></p>
      </div>
    </div>

    <% if @attachments.any? %>
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">Anexos</h2>
        <hr class="border-gray-300 mb-4">
        <div class="space-y-2">
          <% @attachments.each do |attachment| %>
            <div class="flex items-center justify-between border rounded p-3">
              <%= link_to attachment.file.filename, rails_blob_path(attachment.file, disposition: "attachment"),
                  class: "text-blue-600 text-sm hover:underline" %>
              <% if current_user.admin? || current_user.resident? %>
                <%= button_to "Remover", ticket_attachment_path(@ticket, attachment),
                    method: :delete,
                    data: { turbo_confirm: "Tem certeza?" },
                    class: "text-red-500 text-sm hover:underline" %>
              <% end %>
            </div>
          <% end %>
        </div>

        <% if current_user.admin? || current_user.resident? %>
          <div class="mt-4 border-t pt-4">
            <%= form_with url: ticket_attachments_path(@ticket), multipart: true, class: "flex gap-2" do |f| %>
              <input type="file" name="attachment[file]"
                class="border rounded px-3 py-2 text-sm flex-1">
              <%= f.submit "Enviar Anexo", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700" %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <% if current_user.admin? || current_user.resident? %>
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold text-gray-800 mb-4">Anexos</h2>
          <hr class="border-gray-300 mb-4">
          <%= form_with url: ticket_attachments_path(@ticket), multipart: true, class: "flex gap-2" do |f| %>
            <input type="file" name="attachment[file]"
              class="border rounded px-3 py-2 text-sm flex-1">
            <%= f.submit "Enviar Anexo", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700" %>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold text-gray-800 mb-4">Comentários</h2>
      <hr class="border-gray-300 mb-4">
      <% if @comments.any? %>
        <div class="space-y-4 mb-6">
          <% @comments.each do |comment| %>
            <div class="flex gap-3">
              <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0">
                <span class="text-blue-600 text-sm font-medium"><%= comment.user.name.first.upcase %></span>
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-sm font-medium text-gray-800"><%= comment.user.name %></span>
                  <span class="text-xs text-gray-400"><%= comment.created_at.strftime("%d/%m/%Y %H:%M") %></span>
                </div>
                <p class="text-sm text-gray-700 bg-gray-50 rounded p-3"><%= comment.body %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-400 text-sm mb-6">Nenhum comentário ainda.</p>
      <% end %>

      <%= form_with url: ticket_comments_path(@ticket), model: @comment, class: "space-y-3" do |f| %>
        <div>
          <%= f.label :body, "Adicionar Comentário", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_area :body, rows: 3, placeholder: "Escreva seu comentário...",
              class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
        <%= f.submit "Comentar", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700 cursor-pointer" %>
      <% end %>
    </div>

  </div>

  <div class="space-y-6">
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold text-gray-800 mb-4">Status</h2>
      <hr class="border-gray-300 mb-4">
      <span class="<%= @ticket.ticket_status.is_final? ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %> text-sm px-3 py-1 rounded-full">
        <%= @ticket.ticket_status.name %>
      </span>

      <% if current_user.admin? || current_user.collaborator? %>
        <div class="mt-4 border-t pt-4">
          <p class="text-sm font-medium text-gray-700 mb-2">Atualizar Status</p>
          <%= form_with url: update_status_ticket_path(@ticket), method: :patch, class: "space-y-2" do |f| %>
            <%= select_tag :ticket_status_id,
                options_from_collection_for_select(TicketStatus.all, :id, :name, @ticket.ticket_status_id),
                class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
            <%= f.submit "Atualizar", class: "w-full bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700 cursor-pointer" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

</div>