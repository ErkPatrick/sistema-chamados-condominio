<% content_for(:title, "Chamados") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Chamados</h1>
  <% if current_user.admin? || current_user.resident? %>
    <%= link_to "Novo Chamado", new_ticket_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
  <% end %>
</div>

<div class="bg-white rounded-lg shadow p-4 mb-4">
  <%= form_with url: tickets_path, method: :get, class: "flex gap-3 items-end flex-wrap" do |f| %>
    <div>
      <%= f.label :ticket_type_id, "Tipo", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :ticket_type_id, @ticket_types.map { |t| [t.title, t.id] },
          { include_blank: "Todos" },
          class: "border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :ticket_status_id, "Status", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :ticket_status_id, @ticket_statuses.map { |s| [s.name, s.id] },
          { include_blank: "Todos" },
          class: "border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :date_from, "Data de abertura", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :date_from, value: params[:date_from],
          class: "border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :date_to, "Data de fechamento", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :date_to, value: params[:date_to],
          class: "border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    <%= f.submit "Filtrar", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700 cursor-pointer" %>
    <% if params[:ticket_type_id].present? || params[:ticket_status_id].present? || params[:date_from].present? || params[:date_to].present? %>
      <%= link_to "Limpar", tickets_path, class: "bg-gray-200 text-gray-700 px-4 py-2 rounded text-sm hover:bg-gray-300" %>
    <% end %>
  <% end %>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50">
      <tr class="text-left text-gray-500">
        <th class="px-4 py-3">ID</th>
        <th class="px-4 py-3">Unidade</th>
        <th class="px-4 py-3">Tipo</th>
        <th class="px-4 py-3">Status</th>
        <th class="px-4 py-3">Aberto em</th>
        <th class="px-4 py-3">SLA</th>
      </tr>
    </thead>
    <tbody>
      <% if @tickets.any? %>
        <% @tickets.each do |ticket| %>
          <tr class="border-t hover:bg-gray-50 cursor-pointer" onclick="window.location='<%= ticket_path(ticket) %>'">
            <td class="px-4 py-3">#<%= ticket.id %></td>
            <td class="px-4 py-3"><%= ticket.unit.identifier %></td>
            <td class="px-4 py-3"><%= ticket.ticket_type.title %></td>
            <td class="px-4 py-3">
              <span class="<%= ticket.ticket_status.is_final? ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %> text-xs px-2 py-1 rounded">
                <%= ticket.ticket_status.name %>
              </span>
            </td>
            <td class="px-4 py-3"><%= ticket.opened_at.strftime("%d/%m/%Y") %></td>
            <td class="px-4 py-3">
              <% sla_deadline = ticket.opened_at + ticket.ticket_type.sla_hours.hours %>
              <% if ticket.ticket_status.is_final? %>
                <span class="text-green-600">Concluído</span>
              <% elsif Time.current > sla_deadline %>
                <span class="text-red-600 font-medium">Atrasado</span>
              <% else %>
                <span class="text-gray-600"><%= sla_deadline.strftime("%d/%m/%Y") %></span>
              <% end %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr><td colspan="6" class="px-4 py-6 text-center text-gray-400">Nenhum chamado encontrado.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>