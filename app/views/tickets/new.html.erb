<% content_for(:title, "Novo Chamado") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Novo Chamado</h1>
  <%= link_to "Voltar", tickets_path, class: "bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300" %>
</div>

<div class="bg-white rounded-lg shadow p-6">
  <%= form_with model: @ticket, class: "space-y-4" do |f| %>
    <% if @ticket.errors.any? %>
      <div class="bg-red-100 text-red-800 px-4 py-3 rounded">
        <p class="font-semibold mb-1"><%= pluralize(@ticket.errors.count, "erro") %> encontrado(s):</p>
        <ul class="list-disc list-inside text-sm">
          <% @ticket.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :unit_id, "Unidade", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :unit_id, @units.map { |u| [u.identifier, u.id] },
          { prompt: "Selecione uma unidade" },
          class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :ticket_type_id, "Tipo de Chamado", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :ticket_type_id, @ticket_types.map { |t| [t.title, t.id] },
          { prompt: "Selecione um tipo" },
          class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :description, "Descrição", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :description, rows: 4, placeholder: "Descreva o problema detalhadamente...",
          class: "w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Anexos</label>
      <input type="file" name="attachments[]" multiple
        class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      <p class="text-xs text-gray-400 mt-1">Você pode selecionar múltiplos arquivos.</p>
    </div>

    <div class="flex gap-2 pt-2">
      <%= f.submit "Abrir Chamado", class: "bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "Cancelar", tickets_path, class: "bg-gray-200 text-gray-700 px-6 py-2 rounded hover:bg-gray-300" %>
    </div>
  <% end %>
</div>